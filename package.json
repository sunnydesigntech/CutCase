{
  "name": "cutcase",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "npm run bundle:preview && node scripts/build.mjs",
    "bundle:preview": "esbuild preview3d.js --bundle --minify --format=iife --global-name=CutCasePreview3D --outfile=preview3d.bundle.js",
