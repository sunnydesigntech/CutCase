{
  "name": "cutcase",
  "version": "0.1.0",
  "description": "Browser-based laser-cut finger-joint box designer with SVG export, 3D preview, lids, dividers, and editable panel features.",
  "private": true,
  "homepage": "https://sunnydesigntech.github.io/CutCase/",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sunnydesigntech/CutCase.git"
  },
  "bugs": {
    "url": "https://github.com/sunnydesigntech/CutCase/issues"
  },
  "keywords": [
    "laser-cutting",
    "finger-joints",
    "box-generator",
    "svg",
    "threejs",
    "maker"
  ],
  "scripts": {
    "build": "npm run bundle:preview && node scripts/build.mjs",
    "bundle:preview": "esbuild preview3d.js --bundle --minify --format=iife --global-name=CutCasePreview3D --outfile=preview3d.bundle.js",
    "serve": "python3 -m http.server 5173",
    "test": "node test.js",
    "verify:ui": "node verify-ui.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "playwright-core": "^1.59.1"
  },
  "dependencies": {
    "three": "^0.164.1"
  }
}
